{
  "description": "标签页 组件属性",
  "type": "object",
  "properties": {
    "items": {
      "type": "array",
      "title": "标签数据",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "type": {
      "type": "string",
      "title": "标签类型",
      "x-group": "基础属性",
      "x-priority": 11,
      "default": "'line'",
      "oneOf": [
        {
          "const": "card",
          "title": "卡片"
        },
        {
          "const": "editable-card",
          "title": "可编辑卡片"
        },
        {
          "const": "line",
          "title": "线条"
        }
      ]
    },
    "activeKey": {
      "type": "string",
      "title": "当前激活标签",
      "x-group": "基础属性",
      "x-priority": 12
    },
    "defaultActiveKey": {
      "type": "string",
      "title": "默认激活标签",
      "x-group": "基础属性",
      "x-priority": 13
    },
    "tabPlacement": {
      "type": "string",
      "title": "标签放置位置",
      "x-group": "基础属性",
      "x-priority": 15,
      "default": "top",
      "oneOf": [
        {
          "const": "bottom",
          "title": "底部"
        },
        {
          "const": "end",
          "title": "结束"
        },
        {
          "const": "start",
          "title": "起始"
        },
        {
          "const": "top",
          "title": "顶部"
        }
      ]
    },
    "size": {
      "type": "string",
      "title": "尺寸",
      "x-group": "基础属性",
      "x-priority": 16,
      "oneOf": [
        {
          "const": "large",
          "title": "大"
        },
        {
          "const": "middle",
          "title": "居中"
        },
        {
          "const": "small",
          "title": "小"
        }
      ]
    },
    "centered": {
      "type": "boolean",
      "title": "居中排列",
      "x-group": "基础属性",
      "x-priority": 17
    },
    "hideAdd": {
      "type": "boolean",
      "title": "隐藏添加按钮",
      "x-group": "基础属性",
      "x-priority": 18
    },
    "destroyOnHidden": {
      "type": "boolean",
      "title": "销毁隐藏面板",
      "x-group": "高级属性",
      "x-priority": 20
    },
    "animated": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "inkBar": {
              "type": "boolean"
            },
            "tabPane": {
              "type": "boolean"
            }
          },
          "propertyOrder": [
            "inkBar",
            "tabPane"
          ]
        },
        {
          "type": "boolean"
        }
      ],
      "title": "动画配置",
      "x-group": "高级属性",
      "x-priority": 21
    },
    "direction": {
      "type": "string",
      "title": "方向",
      "x-group": "高级属性",
      "x-priority": 22,
      "oneOf": [
        {
          "const": "ltr",
          "title": "从左到右"
        },
        {
          "const": "rtl",
          "title": "从右到左"
        }
      ]
    },
    "tabBarExtraContent": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "left": {
              "type": "string"
            },
            "right": {
              "type": "string"
            }
          },
          "propertyOrder": [
            "left",
            "right"
          ]
        },
        {
          "type": "string"
        }
      ],
      "title": "附加操作栏内容",
      "x-group": "高级属性",
      "x-priority": 23
    },
    "tabBarGutter": {
      "type": "number",
      "title": "标签栏间距",
      "x-group": "高级属性",
      "x-priority": 24
    },
    "tabBarStyle": {
      "type": "object",
      "title": "标签栏样式",
      "x-group": "高级属性",
      "x-priority": 25
    },
    "addIcon": {
      "type": "string",
      "title": "添加图标",
      "x-group": "高级属性",
      "x-priority": 26
    },
    "moreIcon": {
      "type": "string",
      "title": "更多图标",
      "x-group": "高级属性",
      "x-priority": 27
    },
    "removeIcon": {
      "type": "string",
      "title": "删除图标",
      "x-group": "高级属性",
      "x-priority": 28
    },
    "more": {
      "type": "object",
      "title": "下拉菜单配置",
      "x-group": "高级属性",
      "x-priority": 29,
      "properties": {
        "icon": {
          "type": "string",
          "x-group": "基础属性"
        }
      }
    },
    "indicator": {
      "type": "object",
      "title": "指示器配置",
      "x-group": "高级属性",
      "x-priority": 30,
      "properties": {
        "size": {
          "anyOf": [
            {
              "type": "object",
              "propertyOrder": []
            },
            {
              "type": "number"
            }
          ],
          "x-group": "基础属性"
        },
        "align": {
          "type": "string",
          "enum": [
            "center",
            "end",
            "start"
          ],
          "x-group": "基础属性"
        }
      }
    },
    "locale": {
      "type": "object",
      "title": "国际化文案",
      "x-group": "高级属性",
      "x-priority": 31,
      "properties": {
        "dropdownAriaLabel": {
          "type": "string",
          "x-group": "基础属性"
        },
        "removeAriaLabel": {
          "type": "string",
          "x-group": "基础属性"
        },
        "addAriaLabel": {
          "type": "string",
          "x-group": "基础属性"
        }
      }
    },
    "rootClassName": {
      "type": "string",
      "title": "根节点样式类名",
      "x-group": "高级属性",
      "x-priority": 32
    },
    "id": {
      "type": "string",
      "title": "组件 ID",
      "x-group": "高级属性",
      "x-priority": 33
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}