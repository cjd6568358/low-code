{
  "description": "进度条 组件属性",
  "type": "object",
  "properties": {
    "percent": {
      "type": "number",
      "title": "百分比",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "type": {
      "type": "string",
      "enum": [
        "circle",
        "dashboard",
        "line"
      ],
      "title": "类型",
      "x-group": "基础属性",
      "x-priority": 11,
      "default": "line"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "exception",
        "normal",
        "success"
      ],
      "title": "状态",
      "x-group": "基础属性",
      "x-priority": 12,
      "default": "normal"
    },
    "showInfo": {
      "type": "boolean",
      "title": "显示信息",
      "x-group": "基础属性",
      "x-priority": 13,
      "default": true
    },
    "strokeColor": {
      "type": "string",
      "title": "颜色",
      "x-group": "高级属性",
      "x-priority": 20
    },
    "railColor": {
      "type": "string",
      "title": "轨道颜色",
      "x-group": "高级属性",
      "x-priority": 22
    },
    "size": {
      "anyOf": [
        {
          "type": "array",
          "items": [
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ],
          "minItems": 2,
          "maxItems": 2
        },
        {
          "type": "number"
        }
      ],
      "title": "尺寸",
      "x-group": "高级属性",
      "x-priority": 23
    },
    "strokeWidth": {
      "type": "number",
      "title": "进度条线的宽度，单位 px",
      "x-group": "高级属性",
      "x-priority": 24
    },
    "strokeLinecap": {
      "type": "string",
      "enum": [
        "butt",
        "round",
        "square"
      ],
      "title": "进度条端点形状",
      "x-group": "高级属性",
      "x-priority": 25
    },
    "success": {
      "type": "object",
      "title": "成功进度条配置",
      "x-group": "高级属性",
      "x-priority": 26,
      "properties": {
        "percent": {
          "type": "number",
          "title": "成功进度百分比",
          "x-group": "基础属性"
        },
        "strokeColor": {
          "type": "string",
          "title": "成功进度条颜色",
          "x-group": "基础属性"
        }
      }
    },
    "gapDegree": {
      "type": "number",
      "title": "仪表盘进度条缺口角度（0-295）",
      "x-group": "高级属性",
      "x-priority": 30
    },
    "gapPlacement": {
      "type": "string",
      "enum": [
        "bottom",
        "end",
        "start",
        "top"
      ],
      "title": "仪表盘进度条缺口位置",
      "x-group": "高级属性",
      "x-priority": 31
    },
    "steps": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "count": {
              "description": "分步数",
              "type": "number"
            },
            "gap": {
              "description": "每步间距",
              "type": "number"
            }
          },
          "propertyOrder": [
            "count",
            "gap"
          ]
        },
        {
          "type": "number"
        }
      ],
      "title": "进度条分步数（圆环/仪表盘类型下生效）",
      "x-group": "高级属性",
      "x-priority": 32
    },
    "percentPosition": {
      "type": "object",
      "title": "百分比标签位置",
      "x-group": "高级属性",
      "x-priority": 33,
      "properties": {
        "align": {
          "type": "string",
          "enum": [
            "center",
            "end",
            "start"
          ],
          "title": "对齐方式",
          "x-group": "基础属性"
        },
        "type": {
          "type": "string",
          "enum": [
            "inner",
            "outer"
          ],
          "title": "显示位置",
          "x-group": "基础属性"
        }
      }
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}