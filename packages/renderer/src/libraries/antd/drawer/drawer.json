{
  "description": "抽屉 组件属性",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "title": "标题",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "open": {
      "type": "boolean",
      "title": "打开",
      "x-group": "基础属性",
      "x-priority": 11
    },
    "placement": {
      "type": "string",
      "enum": [
        "bottom",
        "left",
        "right",
        "top"
      ],
      "title": "位置",
      "x-group": "基础属性",
      "x-priority": 12,
      "default": "right"
    },
    "width": {
      "type": [
        "string",
        "number"
      ],
      "title": "宽度",
      "x-group": "基础属性",
      "x-priority": 13,
      "default": 256
    },
    "height": {
      "type": [
        "string",
        "number"
      ],
      "title": "高度",
      "x-group": "基础属性",
      "x-priority": 14
    },
    "closable": {
      "type": "boolean",
      "title": "可关闭",
      "x-group": "基础属性",
      "x-priority": 15,
      "default": true
    },
    "mask": {
      "type": "boolean",
      "title": "遮罩",
      "x-group": "基础属性",
      "x-priority": 16,
      "default": true
    },
    "footer": {
      "type": "string",
      "title": "底部",
      "x-group": "高级属性",
      "x-priority": 20
    },
    "loading": {
      "type": "boolean",
      "title": "加载中",
      "x-group": "高级属性",
      "x-priority": 21
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}