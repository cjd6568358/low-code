{
  "description": "弹性布局 组件属性",
  "type": "object",
  "properties": {
    "orientation": {
      "type": "string",
      "title": "排列方向",
      "x-group": "基础属性",
      "x-priority": 11,
      "default": "horizontal",
      "oneOf": [
        {
          "const": "horizontal",
          "title": "水平"
        },
        {
          "const": "vertical",
          "title": "垂直"
        }
      ]
    },
    "wrap": {
      "enum": [
        false,
        "nowrap",
        true,
        "wrap",
        "wrap-reverse"
      ],
      "title": "换行",
      "x-group": "基础属性",
      "x-priority": 12,
      "default": "nowrap"
    },
    "justify": {
      "type": "string",
      "title": "主轴对齐",
      "x-group": "基础属性",
      "x-priority": 13,
      "default": "flex-start",
      "oneOf": [
        {
          "const": "center",
          "title": "居中"
        },
        {
          "const": "flex-end",
          "title": "末尾对齐"
        },
        {
          "const": "flex-start",
          "title": "起始对齐"
        },
        {
          "const": "space-around",
          "title": "环绕对齐"
        },
        {
          "const": "space-between",
          "title": "两端对齐"
        },
        {
          "const": "space-evenly",
          "title": "均分对齐"
        }
      ]
    },
    "align": {
      "type": "string",
      "title": "交叉轴对齐",
      "x-group": "基础属性",
      "x-priority": 14,
      "default": "stretch",
      "oneOf": [
        {
          "const": "baseline",
          "title": "基线"
        },
        {
          "const": "center",
          "title": "居中"
        },
        {
          "const": "flex-end",
          "title": "末尾对齐"
        },
        {
          "const": "flex-start",
          "title": "起始对齐"
        },
        {
          "const": "stretch",
          "title": "拉伸"
        }
      ]
    },
    "flex": {
      "type": [
        "string",
        "number"
      ],
      "title": "flex 属性简写",
      "x-group": "基础属性",
      "x-priority": 15
    },
    "gap": {
      "type": [
        "string",
        "number"
      ],
      "title": "间距，支持预设尺寸或具体数值",
      "x-group": "基础属性",
      "x-priority": 16,
      "default": 8
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}