{
  "description": "文字提示 组件属性",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "title": "提示内容",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "placement": {
      "type": "string",
      "enum": [
        "bottom",
        "bottomLeft",
        "bottomRight",
        "left",
        "leftBottom",
        "leftTop",
        "right",
        "rightBottom",
        "rightTop",
        "top",
        "topLeft",
        "topRight"
      ],
      "title": "位置",
      "x-group": "基础属性",
      "x-priority": 11,
      "default": "top"
    },
    "color": {
      "type": "string",
      "title": "颜色",
      "x-group": "基础属性",
      "x-priority": 12
    },
    "arrow": {
      "type": "boolean",
      "title": "箭头",
      "x-group": "基础属性",
      "x-priority": 13
    },
    "overlay": {
      "type": "string",
      "title": "提示内容（替代 title）",
      "x-group": "基础属性",
      "x-priority": 14
    },
    "open": {
      "type": "boolean",
      "title": "受控显隐",
      "x-group": "基础属性",
      "x-priority": 15
    },
    "defaultOpen": {
      "type": "boolean",
      "title": "默认显隐",
      "x-group": "基础属性",
      "x-priority": 16
    },
    "autoAdjustOverflow": {
      "type": "boolean",
      "title": "自动调整弹出位置",
      "x-group": "基础属性",
      "x-priority": 17
    },
    "destroyOnHidden": {
      "type": "boolean",
      "title": "关闭时销毁内容",
      "x-group": "基础属性",
      "x-priority": 18
    },
    "className": {
      "type": "string",
      "title": "CSS 类名",
      "x-group": "样式",
      "x-priority": 30
    },
    "rootClassName": {
      "type": "string",
      "title": "根节点类名",
      "x-group": "样式",
      "x-priority": 31
    },
    "openClassName": {
      "type": "string",
      "title": "展开时的类名",
      "x-group": "样式",
      "x-priority": 32
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}