    "openClassName": {
      "type": "string",
      "title": "展开时的类名",
      "x-group": "样式",
      "x-priority": 32
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
