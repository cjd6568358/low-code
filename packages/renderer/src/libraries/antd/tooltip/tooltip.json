{
  "description": "文字提示 组件属性",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "title": "提示内容",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "placement": {
      "type": "string",
      "title": "位置",
      "x-group": "基础属性",
      "x-priority": 11,
      "default": "top",
      "oneOf": [
        {
          "const": "bottom",
          "title": "底部"
        },
        {
          "const": "bottomLeft",
          "title": "左下"
        },
        {
          "const": "bottomRight",
          "title": "右下"
        },
        {
          "const": "left",
          "title": "左"
        },
        {
          "const": "leftBottom",
          "title": "左下"
        },
        {
          "const": "leftTop",
          "title": "左上"
        },
        {
          "const": "right",
          "title": "右"
        },
        {
          "const": "rightBottom",
          "title": "右下"
        },
        {
          "const": "rightTop",
          "title": "右上"
        },
        {
          "const": "top",
          "title": "顶部"
        },
        {
          "const": "topLeft",
          "title": "左上"
        },
        {
          "const": "topRight",
          "title": "右上"
        }
      ]
    },
    "color": {
      "type": "string",
      "title": "颜色",
      "x-group": "基础属性",
      "x-priority": 12
    },
    "arrow": {
