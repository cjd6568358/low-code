      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}