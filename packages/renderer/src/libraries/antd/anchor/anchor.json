{
  "description": "锚点 组件属性",
  "type": "object",
  "properties": {
    "items": {
      "type": "array",
      "title": "锚点数据",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "direction": {
      "type": "string",
      "title": "方向",
      "x-group": "基础属性",
      "x-priority": 11,
      "default": "vertical",
      "oneOf": [
        {
          "const": "horizontal",
          "title": "水平"
        },
        {
          "const": "vertical",
          "title": "垂直"
        }
      ]
    },
    "affix": {
      "type": "boolean",
      "title": "固定模式",
      "x-group": "基础属性",
      "x-priority": 12,
      "default": true
    },
    "offsetTop": {
      "type": "number",
      "title": "偏移顶部",
      "x-group": "基础属性",
      "x-priority": 13
    },
    "targetOffset": {
      "type": "number",
      "title": "锚点偏移",
      "x-group": "基础属性",
      "x-priority": 14
    },
    "bounds": {
      "type": "number",
      "title": "锚点区域边界偏移量",
      "x-group": "基础属性",
      "x-priority": 15
    },
    "showInkInFixed": {
      "type": "boolean",
      "title": "固定模式是否显示小方块",
      "x-group": "基础属性",
      "x-priority": 16
    },
    "getContainer": {
      "type": "string",
      "title": "获取滚动容器的 CSS 选择器",
      "x-group": "基础属性",
      "x-priority": 17
    },
    "replace": {
      "type": "boolean",
      "title": "是否替换浏览器历史记录",
      "x-group": "基础属性",
      "x-priority": 18
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}