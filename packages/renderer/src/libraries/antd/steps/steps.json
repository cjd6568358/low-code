{
  "description": "步骤条 组件属性",
  "type": "object",
  "properties": {
    "items": {
      "type": "array",
      "title": "步骤数据",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "current": {
      "type": "number",
      "title": "当前步骤",
      "x-group": "基础属性",
      "x-priority": 11
    },
    "orientation": {
      "type": "string",
      "enum": [
        "horizontal",
        "vertical"
      ],
      "title": "排列方向",
      "x-group": "基础属性",
      "x-priority": 13,
      "default": "horizontal"
    },
    "size": {
      "type": "string",
      "enum": [
        "default",
        "medium",
        "small"
      ],
      "title": "尺寸",
      "x-group": "基础属性",
      "x-priority": 14
    },
    "type": {
      "type": "string",
      "enum": [
        "default",
        "dot",
        "inline",
        "navigation",
        "panel"
      ],
      "title": "类型",
      "x-group": "基础属性",
      "x-priority": 15
    },
    "titlePlacement": {
      "type": "string",
      "enum": [
        "horizontal",
        "vertical"
      ],
      "title": "标题放置位置",
      "x-group": "基础属性",
      "x-priority": 16
    },
    "status": {
      "type": "string",
      "enum": [
        "error",
        "finish",
        "process",
        "wait"
      ],
      "title": "状态",
      "x-group": "基础属性",
      "x-priority": 17
    },
    "initial": {
      "type": "number",
      "title": "初始步骤",
      "x-group": "基础属性",
      "x-priority": 18
    },
    "variant": {
      "type": "string",
      "enum": [
        "filled",
        "outlined"
      ],
      "title": "变体风格",
      "x-group": "高级属性",
      "x-priority": 20,
      "default": "filled"
    },
    "progressDot": {
      "type": "boolean",
      "title": "点状步骤",
      "x-group": "高级属性",
      "x-priority": 21
    },
    "responsive": {
      "type": "boolean",
      "title": "响应式布局",
      "x-group": "高级属性",
      "x-priority": 22
    },
    "ellipsis": {
      "type": "boolean",
      "title": "文字自动省略",
      "x-group": "高级属性",
      "x-priority": 23
    },
    "offset": {
      "type": "number",
      "title": "偏移量（inline 模式下生效）",
      "x-group": "高级属性",
      "x-priority": 24
    },
    "percent": {
      "type": "number",
      "title": "百分比进度",
      "x-group": "高级属性",
      "x-priority": 25
    },
    "rootClassName": {
      "type": "string",
      "title": "根节点样式类名",
      "x-group": "高级属性",
      "x-priority": 26
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}