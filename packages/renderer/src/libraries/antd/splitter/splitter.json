{
  "description": "分隔面板 组件属性",
  "type": "object",
  "properties": {
    "orientation": {
      "type": "string",
      "enum": [
        "horizontal",
        "vertical"
      ],
      "title": "布局方向（替代 layout）",
      "x-group": "基础属性",
      "x-priority": 11,
      "default": "horizontal"
    },
    "vertical": {
      "type": "boolean",
      "title": "是否垂直布局（orientation 的快捷方式）",
      "x-group": "基础属性",
      "x-priority": 12
    },
    "collapsible": {
      "type": "object",
      "title": "折叠配置",
      "x-group": "基础属性",
      "x-priority": 13,
      "properties": {
        "motion": {
          "type": "boolean",
          "title": "是否开启折叠动画",
          "x-group": "基础属性"
        },
        "icon": {
          "type": "object",
          "title": "折叠图标配置",
          "x-group": "基础属性",
          "properties": {
            "start": {
              "type": "string",
              "title": "起始方向图标",
              "x-group": "基础属性"
            },
            "end": {
              "type": "string",
              "title": "结束方向图标",
              "x-group": "基础属性"
            }
          }
        }
      }
    },
    "draggerIcon": {
      "type": "string",
      "title": "拖拽图标",
      "x-group": "基础属性",
      "x-priority": 30
    },
    "lazy": {
      "type": "boolean",
      "title": "懒加载",
      "x-group": "高级属性",
      "x-priority": 40
    },
    "destroyOnHidden": {
      "type": "boolean",
      "title": "隐藏时销毁",
      "x-group": "高级属性",
      "x-priority": 41
    },
    "onDraggerDoubleClick": {
      "type": "string",
      "title": "拖拽条双击事件",
      "x-group": "事件",
      "x-priority": 50
    },
    "onResizeStart": {
      "type": "string",
      "title": "开始调整大小事件",
      "x-group": "事件",
      "x-priority": 51
    },
    "onResize": {
      "type": "string",
      "title": "调整大小事件",
      "x-group": "事件",
      "x-priority": 52
    },
    "onResizeEnd": {
      "type": "string",
      "title": "结束调整大小事件",
      "x-group": "事件",
      "x-priority": 53
    },
    "onCollapse": {
      "type": "string",
      "title": "折叠事件",
      "x-group": "事件",
      "x-priority": 54
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}