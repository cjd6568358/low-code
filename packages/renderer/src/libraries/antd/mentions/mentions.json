{
  "description": "提及 组件属性",
  "type": "object",
  "properties": {
    "options": {
      "type": "array",
      "title": "选项数据",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "placeholder": {
      "type": "string",
      "title": "占位提示",
      "x-group": "基础属性",
      "x-priority": 11
    },
    "value": {
      "type": "string",
      "title": "值",
      "x-group": "基础属性",
      "x-priority": 12
    },
    "defaultValue": {
      "type": "string",
      "title": "默认值",
      "x-group": "基础属性",
      "x-priority": 13,
      "x-no-binding": ""
    },
    "prefix": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "string"
        }
      ],
      "title": "触发前缀",
      "x-group": "基础属性",
      "x-priority": 14,
      "x-no-binding": ""
    },
    "split": {
      "type": "string",
      "title": "分隔符",
      "x-group": "基础属性",
      "x-priority": 15,
      "x-no-binding": ""
    },
    "disabled": {
      "type": "boolean",
      "title": "禁用",
      "x-group": "基础属性",
      "x-priority": 16
    },
    "readOnly": {
      "type": "boolean",
      "title": "只读",
      "x-group": "基础属性",
      "x-priority": 17,
      "x-no-binding": ""
    },
    "autoFocus": {
      "type": "boolean",
      "title": "自动聚焦",
      "x-group": "基础属性",
      "x-priority": 18,
      "x-no-binding": ""
    },
    "rows": {
      "type": "number",
      "title": "行数",
      "x-group": "基础属性",
      "x-priority": 20
    },
    "autoSize": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "minRows": {
              "type": "number"
            },
            "maxRows": {
              "type": "number"
            }
          },
          "propertyOrder": [
            "minRows",
            "maxRows"
          ]
        },
        {
          "type": "boolean"
        }
      ],
      "title": "自适应高度",
      "x-group": "基础属性",
      "x-priority": 21,
      "x-no-binding": ""
    },
    "maxLength": {
      "type": "number",
      "title": "最大长度",
      "x-group": "基础属性",
      "x-priority": 22
    },
    "allowClear": {
      "type": "boolean",
      "title": "允许清除",
      "x-group": "基础属性",
      "x-priority": 23,
      "x-no-binding": ""
    },
    "size": {
      "type": "string",
      "title": "尺寸",
      "x-group": "基础属性",
      "x-priority": 30,
      "x-no-binding": "",
      "oneOf": [
        {
          "const": "large",
          "title": "大"
        },
        {
          "const": "middle",
          "title": "居中"
        },
        {
          "const": "small",
          "title": "小"
        }
      ]
    },
    "variant": {
      "type": "string",
      "title": "形态变体",
      "x-group": "基础属性",
      "x-priority": 31,
      "x-no-binding": "",
      "oneOf": [
        {
          "const": "borderless",
          "title": "无边框"
        },
        {
          "const": "filled",
          "title": "填充"
        },
        {
          "const": "outlined",
          "title": "描边"
        },
        {
          "const": "underlined",
          "title": "下划线"
        }
      ]
    },
    "status": {
      "type": "string",
      "title": "状态",
      "x-group": "基础属性",
      "x-priority": 32,
      "x-no-binding": "",
      "oneOf": [
        {
          "const": "error",
          "title": "错误"
        },
        {
          "const": "warning",
          "title": "警告"
        }
      ]
    },
    "loading": {
      "type": "boolean",
      "title": "加载中",
      "x-group": "基础属性",
      "x-priority": 33
    },
    "notFoundContent": {
      "type": "string",
      "title": "无选项时的内容",
      "x-group": "高级属性",
      "x-priority": 40
    },
    "placement": {
      "type": "string",
      "title": "弹出位置",
      "x-group": "高级属性",
      "x-priority": 41,
      "x-no-binding": "",
      "oneOf": [
        {
          "const": "bottom",
          "title": "底部"
        },
        {
          "const": "top",
          "title": "顶部"
        }
      ]
    },
    "direction": {
      "type": "string",
      "title": "文字方向",
      "x-group": "高级属性",
      "x-priority": 42,
      "x-no-binding": "",
      "oneOf": [
        {
          "const": "ltr",
          "title": "从左到右"
        },
        {
          "const": "rtl",
          "title": "从右到左"
        }
      ]
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}