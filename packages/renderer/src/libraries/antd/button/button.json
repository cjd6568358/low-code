{
  "description": "Button 组件属性",
  "type": "object",
  "properties": {
    "children": {
      "type": "string",
      "title": "按钮内容",
      "x-group": "基础属性",
      "x-priority": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "dashed",
        "default",
        "link",
        "primary",
        "text"
      ],
      "title": "按钮类型",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "htmlType": {
      "type": "string",
      "enum": [
        "button",
        "reset",
        "submit"
      ],
      "title": "HTML 类型",
      "x-group": "基础属性",
      "x-priority": 3
    },
    "shape": {
      "type": "string",
      "enum": [
        "circle",
        "default",
        "round"
      ],
      "title": "形状",
      "x-group": "基础属性",
      "x-priority": 4
    },
    "loading": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "delay": {
              "type": "number"
            }
          },
          "propertyOrder": [
            "delay"
          ]
        },
        {
          "type": "boolean"
        }
      ],
      "title": "加载状态",
      "x-group": "基础属性",
      "x-priority": 5
    },
    "icon": {
      "type": "string",
      "title": "图标",
      "x-group": "高级属性",
      "x-priority": 10
    },
    "iconPlacement": {
      "type": "string",
      "enum": [
        "end",
        "start"
      ],
      "title": "图标位置",
      "x-group": "高级属性",
      "x-priority": 11
    },
    "ghost": {
      "type": "boolean",
      "title": "幽灵按钮",
      "x-group": "高级属性",
      "x-priority": 12
    },
    "danger": {
      "type": "boolean",
      "title": "危险按钮",
      "x-group": "高级属性",
      "x-priority": 13
    },
    "block": {
      "type": "boolean",
      "title": "块级按钮",
      "x-group": "高级属性",
      "x-priority": 14
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}