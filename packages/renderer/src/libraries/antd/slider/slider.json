{
  "description": "滑动条 组件属性",
  "type": "object",
  "properties": {
    "min": {
      "type": "number",
      "title": "最小值",
      "x-group": "基础属性",
      "x-priority": 10,
      "default": 0
    },
    "max": {
      "type": "number",
      "title": "最大值",
      "x-group": "基础属性",
      "x-priority": 11,
      "default": 100
    },
    "step": {
      "type": "number",
      "title": "步长",
      "x-group": "基础属性",
      "x-priority": 12,
      "default": 1
    },
    "value": {
      "anyOf": [
        {
          "type": "array",
          "items": [
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ],
          "minItems": 2,
          "maxItems": 2
        },
        {
          "type": "number"
        }
      ],
      "title": "值",
      "x-group": "基础属性",
      "x-priority": 13
    },
    "range": {
      "type": "boolean",
      "title": "双滑块",
      "x-group": "基础属性",
      "x-priority": 14
    },
    "vertical": {
      "type": "boolean",
      "title": "垂直",
      "x-group": "基础属性",
      "x-priority": 15
    },
    "disabled": {
      "type": "boolean",
      "title": "禁用",
      "x-group": "基础属性",
      "x-priority": 16
    },
    "marks": {
      "type": "object",
      "title": "刻度标记",
      "x-group": "高级属性",
      "x-priority": 20
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}