{
  "description": "骨架屏 组件属性",
  "type": "object",
  "properties": {
    "active": {
      "type": "boolean",
      "title": "动画",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "loading": {
      "type": "boolean",
      "title": "加载中",
      "x-group": "基础属性",
      "x-priority": 11
    },
    "avatar": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "size": {
              "description": "头像尺寸",
              "anyOf": [
                {
                  "enum": [
                    "default",
                    "large",
                    "small"
                  ],
                  "type": "string"
                },
                {
                  "type": "number"
                }
              ]
            },
            "shape": {
              "description": "头像形状",
              "enum": [
                "circle",
                "square"
              ],
              "type": "string"
            }
          },
          "propertyOrder": [
            "size",
            "shape"
          ]
        },
        {
          "type": "boolean"
        }
      ],
      "title": "头像",
      "x-group": "基础属性",
      "x-priority": 12
    },
    "title": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "width": {
              "description": "标题宽度",
              "type": [
                "string",
                "number"
              ]
            }
          },
          "propertyOrder": [
            "width"
          ]
        },
        {
          "type": "boolean"
        }
      ],
      "title": "标题",
      "x-group": "基础属性",
      "x-priority": 13,
      "default": true
    },
    "paragraph": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "rows": {
              "description": "段落行数",
              "type": "number"
            },
            "width": {
              "description": "段落宽度，多行时可传数组分别设置每行宽度",
              "anyOf": [
                {
                  "type": "array",
                  "items": {
                    "type": [
                      "string",
                      "number"
                    ]
                  }
                },
                {
                  "type": [
                    "string",
                    "number"
                  ]
                }
              ]
            }
          },
          "propertyOrder": [
            "rows",
            "width"
          ]
        },
        {
          "type": "boolean"
        }
      ],
      "title": "段落",
      "x-group": "基础属性",
      "x-priority": 14,
      "default": true
    },
    "round": {
      "type": "boolean",
      "title": "圆角",
      "x-group": "高级属性",
      "x-priority": 20
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}