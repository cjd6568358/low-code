      "x-priority": 13
    },
    "allowClear": {
      "type": "boolean",
      "title": "允许清除",
      "x-group": "基础属性",
      "x-priority": 14
    },
    "disabled": {
      "type": "boolean",
      "title": "禁用",
      "x-group": "基础属性",
      "x-priority": 15
    },
    "readOnly": {
      "type": "boolean",
      "title": "只读",
      "x-group": "基础属性",
      "x-priority": 16
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
