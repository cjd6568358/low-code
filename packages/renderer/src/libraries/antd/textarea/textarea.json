{
  "description": "文本域 组件属性",
  "type": "object",
  "properties": {
    "placeholder": {
      "type": "string",
      "title": "占位提示",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "maxLength": {
      "type": "number",
      "title": "最大长度",
      "x-group": "基础属性",
      "x-priority": 11
    },
    "rows": {
      "type": "number",
      "title": "行数",
      "x-group": "基础属性",
      "x-priority": 12
    },
    "autoSize": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "minRows": {
              "type": "number"
            },
            "maxRows": {
              "type": "number"
            }
          },
          "propertyOrder": [
            "minRows",
            "maxRows"
          ]
        },
        {
          "type": "boolean"
        }
      ],
      "title": "自适应高度",
      "x-group": "高级属性",
      "x-priority": 20
    },
    "showCount": {
