{
  "description": "导航菜单 组件属性",
  "type": "object",
  "properties": {
    "items": {
      "type": "array",
      "title": "菜单数据",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "mode": {
      "type": "string",
      "title": "模式",
      "x-group": "基础属性",
      "x-priority": 11,
      "default": "'vertical'",
      "oneOf": [
        {
          "const": "horizontal",
          "title": "水平"
        },
        {
          "const": "inline",
          "title": "内联"
        },
        {
          "const": "vertical",
          "title": "垂直"
        }
      ]
    },
    "theme": {
      "type": "string",
      "title": "主题",
      "x-group": "基础属性",
      "x-priority": 12,
      "default": "light",
      "oneOf": [
        {
          "const": "dark",
          "title": "暗色"
        },
        {
          "const": "light",
          "title": "亮色"
        }
      ]
    },
    "defaultSelectedKeys": {
      "type": "array",
      "title": "默认选中",
      "x-group": "基础属性",
      "x-priority": 13
    },
    "defaultOpenKeys": {
      "type": "array",
      "title": "默认展开",
      "x-group": "基础属性",
      "x-priority": 14
    },
    "selectedKeys": {
      "type": "array",
      "title": "当前选中",
      "x-group": "基础属性",
      "x-priority": 15
    },
    "openKeys": {
      "type": "array",
      "title": "当前展开",
      "x-group": "基础属性",
      "x-priority": 16
    },
    "selectable": {
      "type": "boolean",
      "title": "是否可选中",
      "x-group": "基础属性",
      "x-priority": 17
    },
    "multiple": {
      "type": "boolean",
      "title": "是否允许多选",
      "x-group": "基础属性",
      "x-priority": 18
    },
    "disabled": {
      "type": "boolean",
      "title": "是否禁用",
      "x-group": "基础属性",
      "x-priority": 19
    },
    "inlineIndent": {
      "type": "number",
      "title": "内联缩进宽度",
      "x-group": "基础属性",
      "x-priority": 20
    },
    "inlineCollapsed": {
      "type": "boolean",
      "title": "内联菜单是否收起",
      "x-group": "基础属性",
      "x-priority": 21
    },
    "direction": {
      "type": "string",
      "title": "文字方向",
      "x-group": "高级属性",
      "x-priority": 30,
      "oneOf": [
        {
          "const": "ltr",
          "title": "从左到右"
        },
        {
          "const": "rtl",
          "title": "从右到左"
        }
      ]
    },
    "subMenuOpenDelay": {
      "type": "number",
      "title": "子菜单打开延迟（毫秒）",
      "x-group": "高级属性",
      "x-priority": 31
    },
    "subMenuCloseDelay": {
      "type": "number",
      "title": "子菜单关闭延迟（毫秒）",
      "x-group": "高级属性",
      "x-priority": 32
    },
    "triggerSubMenuAction": {
      "type": "string",
      "title": "子菜单触发方式",
      "x-group": "高级属性",
      "x-priority": 33,
      "oneOf": [
        {
          "const": "click",
          "title": "点击"
        },
        {
          "const": "hover",
          "title": "悬浮"
        }
      ]
    },
    "forceSubMenuRender": {
      "type": "boolean",
      "title": "是否强制渲染子菜单",
      "x-group": "高级属性",
      "x-priority": 34
    },
    "itemIcon": {
      "type": "string",
      "title": "菜单项图标",
      "x-group": "高级属性",
      "x-priority": 35
    },
    "expandIcon": {
      "type": "string",
      "title": "展开图标",
      "x-group": "高级属性",
      "x-priority": 36
    },
    "overflowedIndicator": {
      "type": "string",
      "title": "溢出指示器内容",
      "x-group": "高级属性",
      "x-priority": 37
    },
    "tooltip": {
      "anyOf": [
        {
          "type": "object",
          "propertyOrder": []
        },
        {
          "const": false,
          "type": "boolean"
        }
      ],
      "title": "提示配置，false 可关闭",
      "x-group": "高级属性",
      "x-priority": 38
    },
    "rootClassName": {
      "type": "string",
      "title": "根节点样式类名",
      "x-group": "高级属性",
      "x-priority": 39
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}