{
  "description": "气泡卡片 组件属性",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "title": "标题",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "content": {
      "type": "string",
      "title": "内容",
      "x-group": "基础属性",
      "x-priority": 11
    },
    "placement": {
      "type": "string",
      "title": "位置",
      "x-group": "基础属性",
      "x-priority": 12,
      "default": "top",
      "oneOf": [
        {
          "const": "bottom",
          "title": "底部"
        },
        {
          "const": "bottomLeft",
          "title": "左下"
        },
        {
          "const": "bottomRight",
          "title": "右下"
        },
        {
          "const": "left",
          "title": "左"
        },
        {
          "const": "leftBottom",
          "title": "左下"
        },
        {
          "const": "leftTop",
          "title": "左上"
        },
        {
          "const": "right",
          "title": "右"
        },
        {
          "const": "rightBottom",
          "title": "右下"
        },
        {
          "const": "rightTop",
          "title": "右上"
        },
        {
          "const": "top",
          "title": "顶部"
        },
        {
          "const": "topLeft",
          "title": "左上"
        },
        {
          "const": "topRight",
          "title": "右上"
        }
      ]
    },
    "trigger": {
      "type": "string",
      "title": "触发方式",
      "x-group": "基础属性",
      "x-priority": 13,
      "default": "'hover'",
      "oneOf": [
        {
          "const": "click",
          "title": "点击"
        },
        {
          "const": "contextMenu",
          "title": "右键菜单"
        },
        {
          "const": "focus",
          "title": "聚焦"
        },
        {
          "const": "hover",
          "title": "悬浮"
        }
      ]
    },
    "arrow": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "pointAtCenter": {
              "type": "boolean"
            }
          },
          "propertyOrder": [
            "pointAtCenter"
          ]
        },
        {
          "type": "boolean"
        }
      ],
      "title": "箭头",
      "x-group": "基础属性",
      "x-priority": 14
    },
    "defaultOpen": {
      "type": "boolean",
      "title": "默认是否显示",
      "x-group": "基础属性",
      "x-priority": 15
    },
    "open": {
      "type": "boolean",
      "title": "手动控制显示隐藏",
      "x-group": "基础属性",
      "x-priority": 16
    },
    "onOpenChange": {
      "type": "object",
      "title": "显示隐藏的回调",
      "x-group": "事件",
      "x-priority": 20
    },
    "afterOpenChange": {
      "type": "object",
      "title": "动画结束后的回调",
      "x-group": "事件",
      "x-priority": 21
    },
    "color": {
      "type": "string",
      "title": "背景颜色",
      "x-group": "样式",
      "x-priority": 51
    },
    "className": {
      "type": "string",
      "title": "CSS 类名",
      "x-group": "样式",
      "x-priority": 52
    },
    "rootClassName": {
      "type": "string",
      "title": "根节点 CSS 类名",
      "x-group": "样式",
      "x-priority": 53
    },
    "autoAdjustOverflow": {
      "type": "boolean",
      "title": "气泡被遮挡时自动调整位置",
      "x-group": "高级属性",
      "x-priority": 90
    },
    "destroyOnHidden": {
      "type": "boolean",
      "title": "关闭后是否销毁子节点",
      "x-group": "高级属性",
      "x-priority": 91
    },
    "mouseEnterDelay": {
      "type": "number",
      "title": "鼠标移入延迟（毫秒）",
      "x-group": "高级属性",
      "x-priority": 92
    },
    "mouseLeaveDelay": {
      "type": "number",
      "title": "鼠标移出延迟（毫秒）",
      "x-group": "高级属性",
      "x-priority": 93
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}