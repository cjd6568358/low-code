{
  "description": "输入框 组件属性",
  "type": "object",
  "properties": {
    "placeholder": {
      "type": "string",
      "title": "占位提示",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "maxLength": {
      "type": "number",
      "title": "最大长度",
      "x-group": "基础属性",
      "x-priority": 11
    },
    "allowClear": {
      "type": "boolean",
      "title": "允许清除",
      "x-group": "基础属性",
      "x-priority": 12,
      "x-no-binding": ""
    },
    "showCount": {
      "type": "boolean",
      "title": "显示字数",
      "x-group": "基础属性",
      "x-priority": 13,
      "x-no-binding": ""
    },
    "prefix": {
      "type": "string",
      "title": "前缀",
      "x-group": "高级属性",
      "x-priority": 20
    },
    "suffix": {
      "type": "string",
      "title": "后缀",
      "x-group": "高级属性",
      "x-priority": 21
    },
    "addonBefore": {
      "type": "string",
      "title": "前置标签",
      "x-group": "高级属性",
      "x-priority": 22
    },
    "addonAfter": {
      "type": "string",
      "title": "后置标签",
      "x-group": "高级属性",
      "x-priority": 23
    },
    "disabled": {
      "type": "boolean",
      "title": "禁用",
      "x-group": "基础属性",
      "x-priority": 14,
      "x-no-binding": ""
    },
    "readOnly": {
      "type": "boolean",
      "title": "只读",
      "x-group": "基础属性",
      "x-priority": 15,
      "x-no-binding": ""
    },
    "variant": {
      "type": "string",
      "enum": [
        "borderless",
        "filled",
        "outlined"
      ],
      "title": "变体",
      "x-group": "基础属性",
      "x-priority": 16,
      "x-no-binding": "",
      "default": "'outlined'"
    },
    "size": {
      "type": "string",
      "enum": [
        "large",
        "middle",
        "small"
      ],
      "title": "输入框尺寸",
      "x-group": "基础属性",
      "x-priority": 17,
      "x-no-binding": "",
      "default": "'middle'"
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}