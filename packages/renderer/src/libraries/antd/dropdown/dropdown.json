{
  "description": "下拉菜单 组件属性",
  "type": "object",
  "properties": {
    "menu": {
      "type": "object",
      "title": "菜单配置",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "placement": {
      "type": "string",
      "title": "弹出位置",
      "x-group": "基础属性",
      "x-priority": 11,
      "default": "bottomLeft",
      "oneOf": [
        {
          "const": "bottom",
          "title": "底部"
        },
        {
          "const": "bottomCenter",
          "title": "底部居中"
        },
        {
          "const": "bottomLeft",
          "title": "左下"
        },
        {
          "const": "bottomRight",
          "title": "右下"
        },
        {
          "const": "top",
          "title": "顶部"
        },
        {
          "const": "topCenter",
          "title": "顶部居中"
        },
        {
          "const": "topLeft",
          "title": "左上"
        },
        {
          "const": "topRight",
          "title": "右上"
        }
      ]
    },
    "trigger": {
      "type": "array",
      "title": "触发方式",
      "x-group": "基础属性",
      "x-priority": 12,
      "default": "['hover']"
    },
    "arrow": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "pointAtCenter": {
              "type": "boolean"
            }
          },
          "propertyOrder": [
            "pointAtCenter"
          ]
        },
        {
          "type": "boolean"
        }
      ],
      "title": "箭头",
      "x-group": "基础属性",
      "x-priority": 13
    },
    "open": {
      "type": "boolean",
      "title": "受控展开状态",
      "x-group": "基础属性",
      "x-priority": 14
    },
    "disabled": {
      "type": "boolean",
      "title": "是否禁用",
      "x-group": "基础属性",
      "x-priority": 15
    },
    "autoFocus": {
      "type": "boolean",
      "title": "自动聚焦",
      "x-group": "基础属性",
      "x-priority": 16
    },
    "destroyOnHidden": {
      "type": "boolean",
      "title": "关闭时销毁弹框",
      "x-group": "高级属性",
      "x-priority": 30
    },
    "forceRender": {
      "type": "boolean",
      "title": "强制渲染（非懒加载）",
      "x-group": "高级属性",
      "x-priority": 31
    },
    "mouseEnterDelay": {
      "type": "number",
      "title": "鼠标移入延迟（毫秒）",
      "x-group": "高级属性",
      "x-priority": 32
    },
    "mouseLeaveDelay": {
      "type": "number",
      "title": "鼠标移出延迟（毫秒）",
      "x-group": "高级属性",
      "x-priority": 33
    },
    "autoAdjustOverflow": {
      "type": "boolean",
      "title": "自动调整气泡位置（气泡被遮挡时自动翻转）",
      "x-group": "高级属性",
      "x-priority": 34
    },
    "transitionName": {
      "type": "string",
      "title": "弹出动画名称",
      "x-group": "高级属性",
      "x-priority": 35
    },
    "openClassName": {
      "type": "string",
      "title": "下拉展开时的 CSS 类名",
      "x-group": "高级属性",
      "x-priority": 36
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}