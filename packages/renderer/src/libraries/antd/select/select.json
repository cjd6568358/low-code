      "x-group": "高级属性",
      "x-priority": 56,
      "x-no-binding": ""
    },
    "showAction": {
      "type": "array",
      "title": "触发下拉的行为",
      "x-group": "高级属性",
      "x-priority": 57,
      "x-no-binding": ""
    },
    "prefix": {
      "type": "string",
      "title": "前缀",
      "x-group": "基础属性",
      "x-priority": 60
    },
    "suffix": {
      "type": "string",
      "title": "后缀图标",
      "x-group": "基础属性",
      "x-priority": 61
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
