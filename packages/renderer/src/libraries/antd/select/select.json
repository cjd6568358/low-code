      "x-group": "高级属性",
      "x-priority": 53
    },
    "popupStyle": {
      "type": "object",
      "title": "下拉菜单样式",
      "x-group": "高级属性",
      "x-priority": 54
    },
    "direction": {
      "type": "string",
      "title": "文字方向",
      "x-group": "高级属性",
      "x-priority": 55,
      "x-no-binding": "",
      "oneOf": [
        {
          "const": "ltr",
          "title": "从左到右"
        },
        {
          "const": "rtl",
          "title": "从右到左"
        }
      ]
    },
    "showScrollBar": {
      "enum": [
        false,
        "optional",
        true
