      "x-priority": 40,
      "x-no-binding": "",
      "oneOf": [
        {
          "const": "borderless",
          "title": "无边框"
        },
        {
          "const": "filled",
          "title": "填充"
        },
        {
          "const": "outlined",
          "title": "描边"
        },
        {
          "const": "underlined",
          "title": "下划线"
        }
      ]
    },
    "status": {
      "type": "string",
      "title": "状态",
      "x-group": "高级属性",
      "x-priority": 41,
      "x-no-binding": "",
      "oneOf": [
        {
          "const": "error",
          "title": "错误"
        },
        {
          "const": "warning",
          "title": "警告"
        }
      ]
    },
    "placement": {
      "type": "string",
      "title": "弹出位置",
