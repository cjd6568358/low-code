        {
          "const": "bottomLeft",
          "title": "左下"
        },
        {
          "const": "bottomRight",
          "title": "右下"
        },
        {
          "const": "topLeft",
          "title": "左上"
        },
        {
          "const": "topRight",
          "title": "右上"
        }
      ]
    },
