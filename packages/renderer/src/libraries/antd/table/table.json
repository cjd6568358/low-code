{
  "description": "表格 组件属性",
  "type": "object",
  "properties": {
    "dataSource": {
      "type": "array",
      "title": "数据源",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "columns": {
      "type": "array",
      "title": "列配置",
      "x-group": "基础属性",
      "x-priority": 11
    },
    "bordered": {
      "type": "boolean",
      "title": "边框",
      "x-group": "基础属性",
      "x-priority": 12
    },
    "loading": {
      "type": "boolean",
      "title": "加载中",
      "x-group": "基础属性",
      "x-priority": 13
    },
    "size": {
      "type": "string",
      "enum": [
        "large",
        "middle",
        "small"
      ],
      "title": "尺寸",
      "x-group": "基础属性",
      "x-priority": 14,
      "default": "'large'"
    },
    "column": {
      "type": "object",
      "title": "列统一属性",
      "x-group": "基础属性",
      "x-priority": 15
    },
    "virtual": {
      "type": "boolean",
      "title": "虚拟滚动",
      "x-group": "基础属性",
      "x-priority": 16
    },
    "pagination": {
      "anyOf": [
        {
          "type": "object",
          "properties": {},
          "additionalProperties": true
        },
        {
          "const": false,
          "type": "boolean"
        }
      ],
      "title": "分页",
      "x-group": "高级属性",
      "x-priority": 20
    },
    "scroll": {
      "type": "object",
      "title": "滚动",
      "x-group": "高级属性",
      "x-priority": 21,
      "properties": {
        "x": {
          "type": [
            "string",
            "number"
          ],
          "x-group": "基础属性"
        },
        "y": {
          "type": [
            "string",
            "number"
          ],
          "x-group": "基础属性"
        },
        "scrollToFirstRowOnChange": {
          "type": "boolean",
          "x-group": "基础属性"
        }
      }
    },
    "rowSelection": {
      "type": "object",
      "title": "行选择",
      "x-group": "高级属性",
      "x-priority": 22,
      "properties": {}
    },
    "sortDirections": {
      "type": "array",
      "title": "排序方向",
      "x-group": "高级属性",
      "x-priority": 23
    },
    "showSorterTooltip": {
      "anyOf": [
        {
          "type": "object",
          "propertyOrder": []
        },
        {
          "type": "boolean"
        }
      ],
      "title": "排序提示",
      "x-group": "高级属性",
      "x-priority": 24
    },
    "locale": {
      "type": "object",
      "title": "国际化文案",
      "x-group": "高级属性",
      "x-priority": 25
    },
    "rootClassName": {
      "type": "string",
      "title": "根节点 CSS 类名",
      "x-group": "样式",
      "x-priority": 51
    },
    "getPopupContainer": {
      "type": "string",
      "title": "弹出容器",
      "x-group": "高级属性",
      "x-priority": 26
    },
    "onChange": {
      "type": "string",
      "title": "表格变化回调",
      "x-group": "事件",
      "x-priority": 80
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}