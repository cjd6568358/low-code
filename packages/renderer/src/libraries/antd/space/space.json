{
  "description": "间距 组件属性",
  "type": "object",
  "properties": {
    "orientation": {
      "type": "string",
      "title": "排列方向（替代已废弃的 direction）",
      "x-group": "基础属性",
      "x-priority": 9,
      "default": "horizontal",
      "oneOf": [
        {
          "const": "horizontal",
          "title": "水平"
        },
        {
          "const": "vertical",
          "title": "垂直"
        }
      ]
    },
    "vertical": {
      "type": "boolean",
      "title": "是否垂直方向",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "size": {
      "anyOf": [
        {
          "type": "array",
          "items": [
            {
              "type": [
                "string",
                "number"
              ]
            },
            {
              "type": [
                "string",
                "number"
              ]
            }
          ],
          "minItems": 2,
          "maxItems": 2
        },
        {
          "type": [
            "string",
            "number"
          ]
        }
      ],
      "title": "间距大小，数组形式可分别设置水平和垂直间距",
      "x-group": "基础属性",
      "x-priority": 11
    },
    "wrap": {
      "type": "boolean",
      "title": "自动换行",
      "x-group": "基础属性",
      "x-priority": 12
    },
    "align": {
      "type": "string",
      "title": "对齐",
      "x-group": "基础属性",
      "x-priority": 13,
      "default": "center",
      "oneOf": [
        {
          "const": "baseline",
          "title": "基线"
        },
        {
          "const": "center",
          "title": "居中"
        },
        {
          "const": "end",
          "title": "结束"
        },
        {
          "const": "start",
          "title": "起始"
        }
      ]
    },
    "separator": {
      "type": "string",
      "title": "分隔符（替代已废弃的 split）",
      "x-group": "高级属性",
      "x-priority": 21
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}