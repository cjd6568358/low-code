{
  "description": "二维码 组件属性",
  "type": "object",
  "properties": {
    "value": {
      "type": "string",
      "title": "二维码值",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "size": {
      "type": "number",
      "title": "尺寸（像素）",
      "x-group": "基础属性",
      "x-priority": 11,
      "default": 160
    },
    "status": {
      "type": "string",
      "title": "状态",
      "x-group": "基础属性",
      "x-priority": 12,
      "default": "active",
      "oneOf": [
        {
          "const": "active",
          "title": "激活"
        },
        {
          "const": "expired",
          "title": "已过期"
        },
        {
          "const": "loading",
          "title": "加载中"
        },
        {
          "const": "scanned",
          "title": "已扫描"
        }
      ]
    },
    "type": {
      "type": "string",
      "title": "渲染类型",
      "x-group": "基础属性",
      "x-priority": 13,
      "oneOf": [
        {
          "const": "canvas",
          "title": "Canvas"
        },
        {
          "const": "svg",
          "title": "SVG"
        }
      ]
    },
    "errorLevel": {
      "type": "string",
      "title": "纠错等级",
      "x-group": "基础属性",
      "x-priority": 14,
      "oneOf": [
        {
          "const": "H",
          "title": "高"
        },
        {
          "const": "L",
          "title": "低"
        },
        {
          "const": "M",
          "title": "中"
        },
        {
          "const": "Q",
          "title": "较高"
        }
      ]
    },
    "bordered": {
      "type": "boolean",
      "title": "是否有边框",
      "x-group": "基础属性",
      "x-priority": 15
    },
    "icon": {
      "type": "string",
      "title": "图标地址",
      "x-group": "高级属性",
      "x-priority": 20
    },
    "color": {
      "type": "string",
      "title": "前景色",
      "x-group": "高级属性",
      "x-priority": 21
    },
    "bgColor": {
      "type": "string",
      "title": "背景色",
      "x-group": "高级属性",
      "x-priority": 22
    },
    "boostLevel": {
      "type": "boolean",
      "title": "是否自动提升纠错等级",
      "x-group": "高级属性",
      "x-priority": 23
    },
    "marginSize": {
      "type": "number",
      "title": "边距（模块数）",
      "x-group": "高级属性",
      "x-priority": 24
    },
    "title": {
      "type": "string",
      "title": "无障碍标题",
      "x-group": "高级属性",
      "x-priority": 25
    },
    "minVersion": {
      "type": "number",
      "title": "最小版本（1-40，值越大二维码越复杂）",
      "x-group": "高级属性",
      "x-priority": 26
    },
    "iconSize": {
      "anyOf": [
        {
          "type": "object",
          "propertyOrder": []
        },
        {
          "type": "number"
        }
      ],
      "title": "图标尺寸",
      "x-group": "高级属性",
      "x-priority": 27
    },
    "imageSettings": {
      "type": "object",
      "title": "嵌入图片设置",
      "x-group": "高级属性",
      "x-priority": 28,
      "properties": {
        "src": {
          "type": "string",
          "title": "图片地址",
          "x-group": "基础属性"
        },
        "width": {
          "type": "number",
          "title": "图片宽度（像素）",
          "x-group": "基础属性"
        },
        "height": {
          "type": "number",
          "title": "图片高度（像素）",
          "x-group": "基础属性"
        },
        "excavate": {
          "type": "boolean",
          "title": "是否挖空图片覆盖区域的二维码模块",
          "x-group": "基础属性"
        },
        "x": {
          "type": "number",
          "title": "水平偏移（从左上角开始，不指定则居中）",
          "x-group": "基础属性"
        },
        "y": {
          "type": "number",
          "title": "垂直偏移（从左上角开始，不指定则居中）",
          "x-group": "基础属性"
        },
        "opacity": {
          "type": "number",
          "title": "图片透明度，范围 0-1",
          "x-group": "基础属性"
        },
        "crossOrigin": {
          "type": "string",
          "enum": [
            "",
            "anonymous",
            "use-credentials"
          ],
          "title": "CORS 属性设置",
          "x-group": "基础属性"
        }
      }
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}