{
  "description": "穿梭框 组件属性",
  "type": "object",
  "properties": {
    "dataSource": {
      "type": "array",
      "title": "数据源",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "titles": {
      "type": "array",
      "title": "标题",
      "x-group": "基础属性",
      "x-priority": 11
    },
    "targetKeys": {
      "type": "array",
      "title": "目标列表",
      "x-group": "基础属性",
      "x-priority": 12
    },
    "selectedKeys": {
      "type": "array",
      "title": "选中项",
      "x-group": "基础属性",
      "x-priority": 13
    },
    "showSearch": {
      "type": "boolean",
      "title": "可搜索",
      "x-group": "基础属性",
      "x-priority": 14
    },
    "disabled": {
      "type": "boolean",
      "title": "禁用",
      "x-group": "基础属性",
      "x-priority": 15
    },
    "oneWay": {
      "type": "boolean",
      "title": "单向",
      "x-group": "高级属性",
      "x-priority": 20
    },
    "showSelectAll": {
      "type": "boolean",
      "title": "显示全选勾选框",
      "x-group": "高级属性",
      "x-priority": 21,
      "default": true
    },
    "pagination": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "pageSize": {
              "description": "每页条数",
              "type": "number"
            },
            "simple": {
              "description": "是否使用简单分页",
              "type": "boolean"
            },
            "showSizeChanger": {
              "description": "是否显示分页大小切换器",
              "type": "boolean"
            },
            "showLessItems": {
              "description": "是否显示较少页面",
              "type": "boolean"
            }
          },
          "propertyOrder": [
            "pageSize",
            "simple",
            "showSizeChanger",
            "showLessItems"
          ]
        },
        {
          "type": "boolean"
        }
      ],
      "title": "分页配置，可设为 true 使用默认分页",
      "x-group": "高级属性",
      "x-priority": 22
    },
    "status": {
      "type": "string",
      "enum": [
        "",
        "error",
        "success",
        "validating",
        "warning"
      ],
      "title": "校验状态",
      "x-group": "高级属性",
      "x-priority": 23
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}