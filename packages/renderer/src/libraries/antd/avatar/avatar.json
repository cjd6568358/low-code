{
  "description": "头像 组件属性",
  "type": "object",
  "properties": {
    "src": {
      "type": "string",
      "title": "图片地址",
      "x-group": "基础属性",
      "x-priority": 10
    },
    "size": {
      "type": [
        "string",
        "number"
      ],
      "title": "尺寸",
      "x-group": "基础属性",
      "x-priority": 11
    },
    "shape": {
      "type": "string",
      "title": "形状",
      "x-group": "基础属性",
      "x-priority": 12,
      "default": "circle",
      "oneOf": [
        {
          "const": "circle",
          "title": "圆形"
        },
        {
          "const": "square",
          "title": "方形"
        }
      ]
    },
    "icon": {
      "type": "string",
      "title": "图标",
      "x-group": "基础属性",
      "x-priority": 13
    },
    "alt": {
      "type": "string",
      "title": "图片替代文本",
      "x-group": "基础属性",
      "x-priority": 14
    },
    "srcSet": {
      "type": "string",
      "title": "图片源集（响应式图片 srcset 属性）",
      "x-group": "基础属性",
      "x-priority": 15
    },
    "gap": {
      "type": "number",
      "title": "文字类头像与图片头像两侧之间的间距（像素）",
      "x-group": "基础属性",
      "x-priority": 16
    },
    "draggable": {
      "enum": [
        false,
        "false",
        true,
        "true"
      ],
      "title": "图片是否可拖拽",
      "x-group": "基础属性",
      "x-priority": 17
    },
    "crossOrigin": {
      "type": "string",
      "title": "图片 CORS 属性设置",
      "x-group": "高级属性",
      "x-priority": 20,
      "oneOf": [
        {
          "const": "",
          "title": "无"
        },
        {
          "const": "anonymous",
          "title": "匿名"
        },
        {
          "const": "use-credentials",
          "title": "凭证"
        }
      ]
    },
    "name": {
      "type": "string",
      "title": "字段名称",
      "x-group": "基础属性",
      "x-priority": 0,
      "x-no-binding": "不支持变量/表达式绑定"
    },
    "visible": {
      "type": "boolean",
      "title": "是否可见",
      "x-group": "基础属性",
      "x-priority": 2
    },
    "style": {
      "type": "object",
      "title": "内联样式",
      "x-group": "样式",
      "x-priority": 50
    }
  }
}